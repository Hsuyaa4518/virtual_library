# Rename this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB - Local (MongoDB Compass)
MONGODB_URI=mongodb://localhost:27017/veronicas_library

# MongoDB - Atlas (Cloud, for production)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/veronicas_library?retryWrites=true&w=majority

# JWT
JWT_SECRET=veronicas_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# CORS - Frontend URL
CLIENT_URL=http://localhost:3000

# Fine per day (in USD)
FINE_PER_DAY=1

# Max books a user can borrow at once
MAX_BORROW_LIMIT=5

# Loan period in days
LOAN_PERIOD_DAYS=14
